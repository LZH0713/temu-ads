{
  "manifest_version": 3,
  "name": "Temu Ads ROAS Helper",
  "version": "0.2.5",
  "description": "Read SPU IDs from promotion pages, fetch lowest activity prices, and calculate break-even ROAS.",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab", "tabs", "scripting", "webRequest"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Temu Ads ROAS",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://agentseller.temu.com/*"],
      "js": ["src/anti-content-capture.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/temu-price.js", "src/roas.js", "src/plugin-config.js", "src/cost-sync.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
